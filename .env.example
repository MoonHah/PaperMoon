APP_NAME=PaperMoon
APP_VERSION=0.1.0
DEBUG=false
HOST=0.0.0.0
PORT=8008

# LLM — set LLM_MODE=openai and fill keys to use real model
LLM_MODE=mock
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM Resilience — timeout in seconds and max tenacity retries before fallback
LLM_TIMEOUT=30.0
LLM_MAX_RETRIES=3
EMBEDDING_TIMEOUT=10.0
EMBEDDING_MAX_RETRIES=3

# Embedding — set EMBEDDING_MODE=openai to use real embeddings
EMBEDDING_MODE=mock
EMBEDDING_MODEL=text-embedding-3-small

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Qdrant Vector Database
# 本地开发: http://localhost:6333
# Docker Compose: 由 docker-compose.yml 自动覆盖为 http://qdrant:6333，无需修改
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=papermoon

# PostgreSQL
# 本地开发: postgresql://postgres:<your-password>@localhost:5432/papermoon
# Docker Compose: 由 docker-compose.yml 自动覆盖，无需修改
DATABASE_URL=postgresql://postgres:<your-password>@localhost:5432/papermoon

# Redis / Celery
# 本地开发: redis://localhost:6379/0
# Docker Compose: 由 docker-compose.yml 自动覆盖，无需修改
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
# RATE_LIMIT_ENABLED=true      — set to false to disable globally
# RATE_LIMIT_REQUESTS=60       — max requests per window per IP (or X-User-ID)
# RATE_LIMIT_WINDOW=60         — window size in seconds
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# File storage
STORAGE_PATH=storage
