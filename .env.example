APP_NAME=PaperMoon
APP_VERSION=0.1.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# LLM — set LLM_MODE=openai and fill keys to use real model
LLM_MODE=mock
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding — set EMBEDDING_MODE=openai to use real embeddings
EMBEDDING_MODE=mock
EMBEDDING_MODEL=text-embedding-3-small

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50
